{
  "dashboard": {
    "title": "PHP Trace - Loki Dashboard",
    "uid": "php-trace-loki",
    "tags": ["php", "trace", "loki"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate (spans/sec)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "rate({job=\"php-trace\"} | json | __error__ = \"\" [$__interval])",
            "legendFormat": "Spans/s",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "title": "Error Spans",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "rate({job=\"php-trace\"} | json | status_code = 2 | __error__ = \"\" [$__interval])",
            "legendFormat": "Errors/s",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {"fillOpacity": 20, "lineWidth": 2}
          }
        }
      },
      {
        "id": 3,
        "title": "Top 10 Slowest Operations (P99)",
        "type": "table",
        "gridPos": {"h": 10, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "expr": "topk(10, histogram_quantile(0.99, sum by (operation, le) (rate({job=\"php-trace\"} | json | unwrap duration_ms | __error__ = \"\" [$__rate_interval]))))",
            "format": "table",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "title": "Operation Duration Distribution",
        "type": "heatmap",
        "gridPos": {"h": 10, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "expr": "sum by (operation) (rate({job=\"php-trace\"} | json | unwrap duration_ms [$__interval]))",
            "format": "heatmap",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "title": "Span Details Log",
        "type": "logs",
        "gridPos": {"h": 12, "w": 24, "x": 0, "y": 18},
        "targets": [
          {
            "expr": "{job=\"php-trace\"} | json",
            "refId": "A"
          }
        ],
        "options": {
          "showTime": true,
          "showLabels": true,
          "showCommonLabels": true,
          "wrapLogMessage": false,
          "prettifyLogMessage": true,
          "enableLogDetails": true,
          "dedupStrategy": "none"
        }
      },
      {
        "id": 6,
        "title": "Trace Drop Rate",
        "type": "stat",
        "gridPos": {"h": 4, "w": 4, "x": 0, "y": 30},
        "targets": [
          {
            "expr": "rate({job=\"php-trace\"} | json | __error__ = \"\" [$__interval]) - rate({job=\"php-trace\"} | json | __error__ = \"\" [$__interval])",
            "refId": "A",
            "legendFormat": "Dropped"
          }
        ]
      },
      {
        "id": 7,
        "title": "Average Span Duration",
        "type": "stat",
        "gridPos": {"h": 4, "w": 5, "x": 4, "y": 30},
        "targets": [
          {
            "expr": "avg(rate({job=\"php-trace\"} | json | unwrap duration_ms | __error__ = \"\" [$__interval]))",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms"
          }
        }
      },
      {
        "id": 8,
        "title": "Buffer Dropped Spans",
        "type": "stat",
        "gridPos": {"h": 4, "w": 5, "x": 9, "y": 30},
        "targets": [
          {
            "expr": "sum(rate({job=\"php-trace\"} | json | __error__ = \"\" [$__interval]))",
            "refId": "A"
          }
        ]
      },
      {
        "id": 9,
        "title": "Active Services",
        "type": "stat",
        "gridPos": {"h": 4, "w": 5, "x": 14, "y": 30},
        "targets": [
          {
            "expr": "count(count by (service)({job=\"php-trace\"}))",
            "refId": "A"
          }
        ]
      },
      {
        "id": 10,
        "title": "Unique Operations",
        "type": "stat",
        "gridPos": {"h": 4, "w": 5, "x": 19, "y": 30},
        "targets": [
          {
            "expr": "count(count by (operation)({job=\"php-trace\"}))",
            "refId": "A"
          }
        ]
      }
    ]
  }
}
